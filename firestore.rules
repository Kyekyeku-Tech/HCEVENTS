rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Check if user is an approved admin
    function isApprovedAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection - signup and profile access
    match /users/{userId} {
      // Allow authenticated users to create their own account document during signup
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow admins to read all user profiles
      allow read: if isApprovedAdmin();
      
      // Allow users to update their own profile (except role)
      allow update: if request.auth != null && request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'approved']);
      
      // Allow admins to update user roles and approval status
      allow update: if isApprovedAdmin();
      
      // Allow admins to delete user accounts
      allow delete: if isApprovedAdmin();
    }

    // Services collection - public read, admin write
    match /services/{document=**} {
      // Public read access
      allow read: if true;
      
      // Admin write access
      allow write: if isApprovedAdmin();
    }

    // Portfolio collection - public read, admin write
    match /portfolio/{document=**} {
      // Public read access
      allow read: if true;
      
      // Admin write access
      allow write: if isApprovedAdmin();
    }

    // Blog collection - public read, admin write
    match /blog/{document=**} {
      // Public read access
      allow read: if true;
      
      // Admin write access
      allow write: if isApprovedAdmin();
    }

    // Bookings collection - public create, admin read/write
    match /bookings/{document=**} {
      // Public can create bookings (anyone without auth)
      allow create: if true;
      
      // Admin can read and manage all bookings
      allow read: if isApprovedAdmin();
      allow write: if isApprovedAdmin();
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if isApprovedAdmin();
    }

  }
}
